{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/neovim/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/neovim/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/neovim/help/?$",
			"dest": "_render"
		},
		{
			"src": "^/neovim/projects/?$",
			"dest": "_render"
		},
		{
			"src": "^/neovim/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}